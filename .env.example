# LoopLab Docker-Compose configuration. Copy to `.env` and adjust.
#   cp .env.example .env

# ============================================================================
# LLM — Qwen3-Coder-30B-A3B, 4-bit, served by SGLang on the GPU
# ============================================================================

# HF repo of the 4-bit model. Default is a coding-focused MoE (30B / 3B active), AWQ 4-bit.
#   Default (works on Blackwell today): QuantTrio/Qwen3-Coder-30B-A3B-Instruct-AWQ
#   Other non-hybrid options:           cyankiwi/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit
#
#   NOTE: Qwen3.6-35B-A3B (the originally requested model) is a HYBRID Mamba+MoE and currently
#   CRASHES in SGLang's causal_conv1d Triton kernel on Blackwell (conv-state bf16/fp16 dtype
#   mismatch) — a known upstream bug, NOT fixable by config flags:
#     https://github.com/sgl-project/sglang/issues/24364   (Qwen3.6 hybrid Mamba, Blackwell+WSL2)
#     https://github.com/sgl-project/sglang/issues/19406   (Qwen3.5/3.6 AWQ Mamba dtype mismatch)
#   Re-enable it once SGLang ships the fix:
#     SGLANG_MODEL=QuantTrio/Qwen3.6-35B-A3B-AWQ   LLM_MODEL_NAME=qwen3.6-35b-a3b
SGLANG_MODEL=QuantTrio/Qwen3-Coder-30B-A3B-Instruct-AWQ

# Name the API advertises; LoopLab is pointed at this exact name. Keep both in sync
# (compose passes it to --served-model-name AND LOOPLAB_LLM_MODEL).
LLM_MODEL_NAME=qwen3-coder-30b-a3b

# Max context window to allocate KV cache for. 32k is plenty for LoopLab; raise toward
# the model's native 262144 only if you have VRAM headroom (KV cache grows with this).
SGLANG_CONTEXT_LENGTH=32768

# Fraction of GPU memory SGLang reserves for weights+KV. 0.9 fits the 4-bit 35B on a 32 GB
# RTX 5090 with room for the context above. Lower it if you hit OOM.
SGLANG_MEM_FRACTION=0.9

# Extra SGLang flags (word-split in the container). Adjust parser names if a flag is
# rejected by your SGLang build. AWQ quantization is auto-detected from the model config;
# add `--quantization awq_marlin` here to force it, or `--quantization modelopt_fp4` for NVFP4.
SGLANG_EXTRA_ARGS=--trust-remote-code --tool-call-parser qwen

# Optional Hugging Face token (gated repos / higher download throughput). Leave blank if not needed.
HF_TOKEN=

# Kaggle API token for real MLE-bench runs (the modern KGAT_… Bearer token). Used by
# `looplab.adapters.kaggle_dl` to download competition data. Alternatively put it in
# ~/.kaggle/kaggle.json under "key". See docs/MLEBENCH.md.
LOOPLAB_KAGGLE_TOKEN=

# ============================================================================
# Ports (host side)
# ============================================================================
UI_PORT=8765
SGLANG_PORT=30000
# Host interface to publish on. Default 127.0.0.1 (localhost only) — the UI control-plane is
# UNAUTHENTICATED unless LOOPLAB_UI_TOKEN is set, so it is NOT exposed to the LAN by default.
# To serve beyond localhost: set a token and LOOPLAB_UI_HOSTS below AND set UI_BIND=0.0.0.0
# SGLang has no API authentication in this stack. Keep SGLANG_BIND on loopback/private networking,
# or place an authenticated gateway/firewall in front of :30000; LOOPLAB_UI_TOKEN does not protect it.
UI_BIND=127.0.0.1
SGLANG_BIND=127.0.0.1

# ============================================================================
# LoopLab
# ============================================================================
LOOPLAB_BACKEND=llm
LOOPLAB_LLM_TEMPERATURE=0.6

# Optional UI hardening (leave blank for local single-user, no auth):
#   LOOPLAB_UI_TOKEN — require X-LoopLab-Token on owner reads and mutations
#   LOOPLAB_UI_CORS  — comma-separated allowed origins
#   LOOPLAB_UI_HOSTS — comma-separated public Host names allowed to reach the UI (DNS-rebinding guard)
# NOTE: LOOPLAB_UI_TOKEN isolates users only when each has its OWN origin (this 127.0.0.1 bind, or a
# per-user subdomain). On a SHARED origin (JupyterHub /user/<name>/proxy/<port>/) it is a
# per-deployment secret, NOT per-user — give each user a private origin. See docs/guide/deployment.md.
LOOPLAB_UI_TOKEN=
LOOPLAB_UI_CORS=
LOOPLAB_UI_HOSTS=
