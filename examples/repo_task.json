{
  "kind": "repo",
  "id": "repo_example",
  "goal": "tune config.json to maximize the eval metric (max at x=3)",
  "direction": "max",
  "editable_path": "examples/repo_example",
  "edit_surface": ["*.json"],
  "protect": ["ttrain.py"],
  "eval": {
    "command": ["python", "ttrain.py"],
    "metric": {"kind": "stdout_json", "key": "metric"},
    "timeout": 60
  }
}
